---
type AspectRatio = '16/9' | '4/3' | '1/1' | '3/4';

interface Props {
  src: string;
  alt: string;
  aspectRatio?: AspectRatio;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const {
  src,
  alt,
  aspectRatio = '16/9',
  class: className = '',
  loading = 'lazy',
} = Astro.props;
---

<div class:list={['image', `image--${aspectRatio.replace('/', '-')}`, className]}>
  <img src={src} alt={alt} loading={loading} decoding="async" />
</div>

<style>
  .image {
    overflow: hidden;
    border-radius: var(--radius-md);
    background-color: var(--color-brand-muted);
  }

  .image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image--16-9 {
    aspect-ratio: 16 / 9;
  }

  .image--4-3 {
    aspect-ratio: 4 / 3;
  }

  .image--1-1 {
    aspect-ratio: 1 / 1;
  }

  .image--3-4 {
    aspect-ratio: 3 / 4;
  }
</style>
