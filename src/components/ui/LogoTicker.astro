---
import type { Locale } from '../../config/locales';
import { localizeHref } from '../../lib/i18n';
import type { LogoItem } from '../../types/content';

interface Props {
  logos: LogoItem[];
  locale?: Locale;
  class?: string;
  label?: string;
}

const { logos, locale = 'en', class: className = '', label } = Astro.props;

const SET_COPIES = 8;
const expandedLogos = Array.from({ length: SET_COPIES }, () => logos).flat();
---

<div class:list={['logo-ticker', className]}>
  {label && <p class="logo-ticker__label">{label}</p>}
  <div class="logo-ticker__viewport" data-logo-ticker-viewport>
    <div
      class="logo-ticker__track"
      data-logo-ticker
      data-base-count={logos.length}
    >
      <ul class="logo-ticker__set" aria-label="Partner logos">
        {
          expandedLogos.map((logo) => (
            <li class="logo-ticker__item">
              {logo.href ? (
                <a href={localizeHref(logo.href, locale)} class="logo-ticker__link">
                  <img
                    src={logo.image}
                    alt={logo.alt ?? ''}
                    class="logo-ticker__logo"
                    loading="lazy"
                    draggable="false"
                  />
                </a>
              ) : (
                <img
                  src={logo.image}
                  alt={logo.alt ?? ''}
                  class="logo-ticker__logo"
                  loading="lazy"
                  draggable="false"
                />
              )}
            </li>
          ))
        }
      </ul>
      <ul class="logo-ticker__set" aria-hidden="true">
        {
          expandedLogos.map((logo) => (
            <li class="logo-ticker__item">
              {logo.href ? (
                <a href={localizeHref(logo.href, locale)} class="logo-ticker__link" tabindex="-1">
                  <img src={logo.image} alt="" class="logo-ticker__logo" loading="lazy" draggable="false" />
                </a>
              ) : (
                <img src={logo.image} alt="" class="logo-ticker__logo" loading="lazy" draggable="false" />
              )}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</div>

<style>
  .logo-ticker__label {
    text-align: center;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-subtle);
    margin: 0 0 var(--space-5);
  }

  .logo-ticker__viewport {
    width: 100%;
    overflow: hidden;
    padding-block: var(--space-2);
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-logo) 8%,
      var(--color-logo) 92%,
      transparent 100%
    );
  }

  .logo-ticker__track {
    display: flex;
    align-items: center;
    width: max-content;
    gap: var(--space-8);
    will-change: transform;
  }

  .logo-ticker__track:not(.logo-ticker__track--scroll-driven) {
    animation: logo-ticker-scroll var(--logo-ticker-duration, 120s) linear infinite;
  }

  @keyframes logo-ticker-scroll {
    from {
      transform: translate3d(0, 0, 0);
    }

    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  .logo-ticker__set {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    gap: var(--space-8);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .logo-ticker__item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 11.5rem;
    width: 11.5rem;
    padding: 0;
  }

  .logo-ticker__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    text-decoration: none;
  }

  .logo-ticker__logo {
    display: block;
    width: auto;
    height: auto;
    max-height: 5rem;
    max-width: 9.5rem;
    object-fit: contain;
    object-position: center;
    filter: grayscale(1);
    opacity: 0.72;
    transition:
      filter var(--transition-slow),
      opacity var(--transition-slow);
  }

  .logo-ticker__item:hover .logo-ticker__logo,
  .logo-ticker__item:focus-within .logo-ticker__logo {
    filter: grayscale(0);
    opacity: 1;
  }

  @media (max-width: 768px) {
    .logo-ticker__track {
      gap: var(--space-6);
    }

    .logo-ticker__set {
      gap: var(--space-6);
    }

    .logo-ticker__item {
      flex-basis: 7.5rem;
      width: 7.5rem;
    }

    .logo-ticker__logo {
      max-height: 3.5rem;
      max-width: 6.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-ticker__track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      gap: var(--space-8);
    }

    .logo-ticker__set[aria-hidden='true'] {
      display: none;
    }

    .logo-ticker__viewport {
      mask-image: none;
    }
  }
</style>
