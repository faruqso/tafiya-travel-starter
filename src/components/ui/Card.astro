---
interface Props {
  class?: string;
  padding?: 'none' | 'md';
  hover?: boolean;
}

const { class: className = '', padding = 'md', hover = false } = Astro.props;
---

<div class:list={['card', `card--padding-${padding}`, hover && 'card--hover', className]}>
  <slot />
</div>

<style>
  .card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .card--padding-md {
    padding: var(--space-6);
  }

  .card--padding-none {
    padding: 0;
  }

  .card--hover {
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .card--hover:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
</style>
