---
import { PLUS_GRIDS, type PlusTone } from '../../lib/plus-grid';

interface Props {
  variant: keyof typeof PLUS_GRIDS;
  class?: string;
}

const { variant, class: className = '' } = Astro.props;
const tones = PLUS_GRIDS[variant];
---

<div class:list={['plus-grid', `plus-grid--${variant}`, className]} aria-hidden="true">
  {tones.map((tone: PlusTone) => (
    <span class:list={['plus-grid__item', `plus-grid__item--${tone}`]}>+</span>
  ))}
</div>

<style>
  .plus-grid {
    display: grid;
    grid-template-columns: repeat(5, var(--text-plus-grid));
    gap: 0.625rem 0.875rem;
    pointer-events: none;
    user-select: none;
  }

  .plus-grid--subscribe {
    grid-template-columns: repeat(5, var(--text-plus-grid));
    gap: 0.875rem 1.375rem;
  }

  .plus-grid__item {
    font-family: var(--font-plus-grid);
    font-size: var(--text-plus-grid);
    font-weight: var(--font-weight-normal);
    line-height: 1;
    text-align: center;
  }

  .plus-grid__item--orange {
    color: var(--color-deco-orange);
  }

  .plus-grid__item--purple {
    color: var(--color-deco-purple);
  }

  .plus-grid__item--muted {
    color: var(--color-deco-muted);
  }

  .plus-grid--subscribe .plus-grid__item {
    font-family: var(--font-plus-grid);
    font-size: var(--text-plus-grid);
  }
</style>
