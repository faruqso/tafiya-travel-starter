---
import { locales, getLocaleMeta, ui, type Locale } from '../../config/locales';
import { getLocalizedPath } from '../../lib/i18n';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const current = getLocaleMeta(locale);
const strings = ui[locale];
---

<div class="lang-switcher" data-lang-switcher>
  <button
    type="button"
    class="lang-switcher__trigger"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-controls="lang-switcher-menu"
    id="lang-switcher-trigger"
  >
    <span class="lang-switcher__flag" aria-hidden="true">{current.flag}</span>
    <span class="lang-switcher__code">{locale.toUpperCase()}</span>
    <img
      class="lang-switcher__chevron"
      src="/images/heroes/tafiya/chevron-down.svg"
      alt=""
      width="9"
      height="5"
    />
    <span class="sr-only">{strings.selectLanguage}</span>
  </button>

  <ul
    id="lang-switcher-menu"
    class="lang-switcher__menu"
    role="listbox"
    aria-labelledby="lang-switcher-trigger"
    hidden
  >
    {
      locales.map((entry) => {
        const href = getLocalizedPath(currentPath, entry.code);
        const isActive = entry.code === locale;

        return (
          <li role="none">
            <a
              href={href}
              class:list={['lang-switcher__option', isActive && 'lang-switcher__option--active']}
              role="option"
              aria-selected={isActive}
              hreflang={entry.code}
              lang={entry.code}
            >
              <span class="lang-switcher__flag" aria-hidden="true">
                {entry.flag}
              </span>
              <span class="lang-switcher__label">{entry.label}</span>
              <span class="lang-switcher__code lang-switcher__code--menu">
                {entry.code.toUpperCase()}
              </span>
            </a>
          </li>
        );
      })
    }
  </ul>
</div>

<style>
  .lang-switcher {
    position: relative;
  }

  .lang-switcher__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4375rem;
    padding: 0;
    border: none;
    background: none;
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-weight: var(--font-weight-medium);
    color: var(--color-nav-text);
    cursor: pointer;
  }

  .lang-switcher__trigger[aria-expanded='true'] .lang-switcher__chevron {
    transform: rotate(180deg);
  }

  .lang-switcher__flag {
    font-size: 1.125rem;
    line-height: 1;
  }

  .lang-switcher__chevron {
    transition: transform var(--transition-base);
  }

  .lang-switcher__menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    inset-inline-end: 0;
    z-index: calc(var(--z-header) + 1);
    min-width: 11.5rem;
    margin: 0;
    padding: 0.375rem;
    list-style: none;
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-md);
  }

  .lang-switcher__option {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 0.75rem;
    border-radius: calc(var(--radius-sm) - 2px);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: var(--font-weight-medium);
    color: var(--color-nav-text);
    text-decoration: none;
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  .lang-switcher__option:hover,
  .lang-switcher__option:focus-visible {
    background: var(--color-surface-raised);
    color: var(--color-accent);
    outline: none;
  }

  .lang-switcher__option--active {
    background: var(--color-brand-muted);
    color: var(--color-text);
  }

  .lang-switcher__label {
    flex: 1;
  }

  .lang-switcher__code--menu {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .lang-switcher__option--active .lang-switcher__code--menu {
    color: var(--color-text-secondary);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  function initLanguageSwitchers() {
    document.querySelectorAll('[data-lang-switcher]').forEach((root) => {
      if (!(root instanceof HTMLElement)) return;
      if (root.dataset.initialized === 'true') return;
      root.dataset.initialized = 'true';

      const trigger = root.querySelector('.lang-switcher__trigger');
      const menu = root.querySelector('.lang-switcher__menu');
      if (!(trigger instanceof HTMLButtonElement) || !(menu instanceof HTMLUListElement)) return;

      const close = () => {
        trigger.setAttribute('aria-expanded', 'false');
        menu.hidden = true;
      };

      const open = () => {
        trigger.setAttribute('aria-expanded', 'true');
        menu.hidden = false;
      };

      trigger.addEventListener('click', (event) => {
        event.stopPropagation();
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        if (isOpen) {
          close();
        } else {
          open();
        }
      });

      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', close);
      });

      document.addEventListener('click', (event) => {
        if (!root.contains(event.target as Node)) {
          close();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          close();
          trigger.focus();
        }
      });
    });
  }

  initLanguageSwitchers();
  document.addEventListener('astro:page-load', initLanguageSwitchers);
</script>
