---
type BadgeVariant = 'brand' | 'success' | 'warning' | 'muted' | 'error' | 'on-image';

interface Props {
  label: string;
  variant?: BadgeVariant;
  class?: string;
  title?: string;
}

const { label, variant = 'brand', class: className = '', title } = Astro.props;
---

<span class:list={['badge', `badge--${variant}`, className]} title={title}>{label}</span>
