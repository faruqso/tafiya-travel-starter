---
import LabelSweep from './LabelSweep.astro';
import type { ButtonVariant, ButtonSize } from '../../types/content';

interface Props {
  href?: string;
  label: string;
  variant?: ButtonVariant | 'subscribe' | 'nav-signup';
  size?: ButtonSize;
  type?: 'button' | 'submit';
  disabled?: boolean;
  class?: string;
  /** Sets data-mock-fill for demo login autofill hook */
  mockFill?: boolean;
  /** Sets data-mock-logout for demo auth sign-out hook */
  mockLogout?: boolean;
  /** Redirect path after mock logout (data-logout-redirect) */
  logoutRedirect?: string;
  /** Mock download kind for bookings dashboard */
  mockDownload?: 'itinerary' | 'invoice' | 'receipt';
  /** Booking reference for mock download buttons */
  bookingRef?: string;
  /** Accessible label override */
  ariaLabel?: string;
}

const {
  href,
  label,
  variant = 'primary',
  size = 'md',
  type = 'button',
  disabled = false,
  class: className = '',
  mockFill = false,
  mockLogout = false,
  logoutRedirect,
  mockDownload,
  bookingRef,
  ariaLabel,
} = Astro.props;

const classes = ['btn', `btn--${variant}`, `btn--${size}`, className];
---

{
  href ? (
    <a href={href} class:list={classes}>
      <span class="btn__fill" aria-hidden="true" />
      <LabelSweep label={label} />
    </a>
  ) : (
    <button
      type={type}
      class:list={classes}
      disabled={disabled}
      aria-label={ariaLabel}
      data-mock-fill={mockFill || undefined}
      data-mock-logout={mockLogout || undefined}
      data-logout-redirect={logoutRedirect}
      data-mock-download={mockDownload}
      data-booking-ref={bookingRef}
    >
      <span class="btn__fill" aria-hidden="true" />
      <LabelSweep label={label} />
    </button>
  )
}
