---
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import SubscribeForm from '../ui/SubscribeForm.astro';
import PlusGrid from '../ui/PlusGrid.astro';
import type { SubscribeSection } from '../../types/content';

interface Props {
  section: SubscribeSection['value'];
}

const { section } = Astro.props;
const headline = section.headline.trim().replace(/\s*\n+\s*/g, ' ');
---

<Section variant="default" class="subscribe">
  <Container class="subscribe__container">
    <PlusGrid variant="subscribe" class="subscribe__plus" />

    <div class="subscribe__panel" data-reveal>
      <div class="subscribe__panel-bg" aria-hidden="true"></div>

      <div class="subscribe__deco" aria-hidden="true">
        <img
          src="/images/subscribe/tafiya/lines-bottom-left.svg"
          alt=""
          class="subscribe__lines subscribe__lines--bl"
          width="497"
          height="282"
        />
        <div class="subscribe__lines-wrap subscribe__lines-wrap--tr">
          <img
            src="/images/subscribe/tafiya/lines-top-right.svg"
            alt=""
            class="subscribe__lines subscribe__lines--tr"
            width="275"
            height="156"
          />
        </div>
      </div>

      <img
        src="/images/subscribe/tafiya/send-icon.svg"
        alt=""
        class="subscribe__send"
        width="70"
        height="70"
      />

      <div class="subscribe__content">
        <h2 class="subscribe__headline">{headline}</h2>

        <SubscribeForm buttonLabel={section.buttonLabel} />
      </div>
    </div>
  </Container>
</Section>

<style>
  .subscribe :global(.subscribe__container) {
    position: relative;
    padding-block: 7.5rem 6.5rem;
  }

  .subscribe :global(.subscribe__plus) {
    position: absolute;
    right: var(--container-padding-x);
    bottom: 2.75rem;
    display: none;
  }

  .subscribe__panel {
    position: relative;
    width: 100%;
    max-width: var(--subscribe-shell-max);
    min-height: 25.4375rem;
    margin-inline: auto;
    overflow: visible;
  }

  .subscribe__deco {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: var(--radius-subscribe);
    pointer-events: none;
    z-index: 0;
  }

  .subscribe__panel-bg {
    position: absolute;
    inset: 0;
    background: var(--color-subscribe-bg);
    border-radius: var(--radius-subscribe);
    pointer-events: none;
  }

  .subscribe__lines {
    position: absolute;
    pointer-events: none;
    user-select: none;
    display: block;
  }

  /* Figma 92:1332 — Frame 2, left 23px, bottom 0, 497×282 */
  .subscribe__lines--bl {
    left: 1.4375rem;
    bottom: 0;
    width: 31.0625rem;
    max-width: 42.48%;
    height: auto;
  }

  /* Figma 92:1325 — Frame 3: right 0, top 0, wrapper 156×275, inner 275×156 @ -90° */
  .subscribe__lines-wrap--tr {
    position: absolute;
    right: 0;
    top: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 9.75rem;
    height: 17.1875rem;
    pointer-events: none;
    z-index: 0;
  }

  .subscribe__lines--tr {
    flex: none;
    width: 17.1875rem;
    height: 9.75rem;
    transform: rotate(-90deg);
  }

  /* Figma 92:1339 — centered on top-right corner intersection */
  .subscribe__send {
    position: absolute;
    top: 0;
    right: 0;
    width: 4.375rem;
    height: 4.375rem;
    transform: translate(50%, -50%);
    pointer-events: none;
    z-index: 2;
  }

  .subscribe__content {
    position: relative;
    z-index: 1;
    padding: var(--subscribe-content-padding-y) 1.5rem 4.875rem;
    text-align: center;
  }

  /* Figma 92:1355 — Poppins SemiBold 33px / 54px line-height, #5e6282 */
  .subscribe__headline {
    max-width: var(--subscribe-headline-max-width);
    margin-inline: auto;
    margin-bottom: var(--subscribe-headline-margin-bottom);
    font-family: var(--font-body);
    font-size: clamp(1.125rem, 2.5vw, var(--text-subscribe-headline-max));
    font-weight: var(--font-weight-semibold);
    line-height: var(--leading-subscribe);
    color: var(--color-text-muted);
    text-wrap: balance;
  }

  @media (min-width: 1024px) {
    .subscribe :global(.subscribe__plus) {
      display: grid;
    }
  }

  @media (max-width: 900px) {
    .subscribe__lines-wrap--tr {
      width: 7rem;
      height: 12rem;
      opacity: 0.85;
    }

    .subscribe__lines--tr {
      width: 12rem;
      height: 7rem;
    }

    .subscribe__lines--bl {
      left: 0;
      max-width: 55%;
    }
  }

  @media (max-width: 640px) {
    .subscribe :global(.subscribe__container) {
      padding-block: var(--space-12) var(--space-16);
    }

    .subscribe__panel {
      min-height: auto;
    }

    .subscribe__panel-bg,
    .subscribe__deco {
      border-radius: var(--radius-lg);
    }

    .subscribe__content {
      padding: var(--space-10) var(--space-5) var(--space-10);
    }

    .subscribe__headline {
      margin-bottom: var(--space-8);
    }

    .subscribe__lines {
      opacity: 0.65;
    }

    .subscribe__send {
      top: 0.375rem;
      right: var(--space-4);
      width: 2.75rem;
      height: 2.75rem;
      transform: translateY(-0.125rem);
    }

    .subscribe :global(.subscribe__plus) {
      bottom: 1rem;
    }
  }
</style>
