---
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import SubscribeForm from '../ui/SubscribeForm.astro';
import PlusGrid from '../ui/PlusGrid.astro';
import type { SubscribeSection } from '../../types/content';

interface Props {
  section: SubscribeSection['value'];
}

const { section } = Astro.props;
const headlineLines = section.headline.split('\n').map((l) => l.trim()).filter(Boolean);
---

<Section variant="default" class="subscribe">
  <Container class="subscribe__container">
    <PlusGrid variant="subscribe" class="subscribe__plus" />

    <div class="subscribe__panel">
      <img
        src="/images/subscribe/tafiya/rings-left.svg"
        alt=""
        class="subscribe__rings subscribe__rings--left"
        aria-hidden="true"
        width="480"
        height="361"
      />
      <img
        src="/images/subscribe/tafiya/rings-right.svg"
        alt=""
        class="subscribe__rings subscribe__rings--right"
        aria-hidden="true"
        width="264"
        height="352"
      />

      <img
        src="/images/subscribe/tafiya/send-badge.svg"
        alt=""
        class="subscribe__send"
        aria-hidden="true"
        width="70"
        height="70"
      />

      <div class="subscribe__content">
        <h2 class="subscribe__headline">
          {headlineLines.map((line) => (
            <span class="subscribe__headline-line">{line}</span>
          ))}
        </h2>

        <SubscribeForm buttonLabel={section.buttonLabel} />
      </div>
    </div>
  </Container>
</Section>

<style>
  .subscribe :global(.subscribe__container) {
    position: relative;
    padding-block: 7.5rem 0;
  }

  .subscribe :global(.subscribe__plus) {
    position: absolute;
    right: var(--container-padding-x);
    bottom: 0;
    display: none;
  }

  .subscribe__panel {
    position: relative;
    min-height: 25.4375rem;
    padding: 4.9375rem var(--space-6) 5rem;
    background: var(--color-subscribe-bg);
    border-radius: var(--radius-subscribe);
    overflow: hidden;
  }

  .subscribe__rings {
    position: absolute;
    pointer-events: none;
    user-select: none;
  }

  .subscribe__rings--left {
    left: 0;
    bottom: 0;
    width: min(30rem, 55%);
    height: auto;
    transform: rotate(90deg);
    transform-origin: bottom left;
  }

  .subscribe__rings--right {
    top: 0;
    right: 0;
    width: min(16.5rem, 35%);
    height: auto;
  }

  .subscribe__send {
    position: absolute;
    top: -0.8125rem;
    right: clamp(1rem, 8vw, 7.8125rem);
    width: 4.375rem;
    height: 4.375rem;
    pointer-events: none;
    filter: drop-shadow(0 8px 16px rgba(116, 125, 239, 0.35));
  }

  .subscribe__content {
    position: relative;
    z-index: 1;
    max-width: 44.625rem;
    margin-inline: auto;
    text-align: center;
  }

  .subscribe__headline {
    font-family: var(--font-body);
    font-size: clamp(1.375rem, 2.5vw, 2.0625rem);
    font-weight: var(--font-weight-semibold);
    line-height: 1.636;
    color: var(--color-text-muted);
    margin-bottom: 3.375rem;
  }

  .subscribe__headline-line {
    display: block;
  }

  @media (min-width: 1024px) {
    .subscribe :global(.subscribe__plus) {
      display: grid;
    }

    .subscribe__headline {
      line-height: 1.636;
    }
  }

  @media (max-width: 640px) {
    .subscribe :global(.subscribe__container) {
      padding-block: var(--space-12) 0;
    }

    .subscribe__panel {
      min-height: auto;
      padding: var(--space-10) var(--space-5) var(--space-12);
      border-radius: var(--radius-lg);
    }

    .subscribe__rings {
      opacity: 0.6;
    }

    .subscribe__send {
      width: 3rem;
      height: 3rem;
      top: -0.5rem;
      right: var(--space-4);
    }

    .subscribe__headline {
      margin-bottom: var(--space-8);
    }
  }
</style>
