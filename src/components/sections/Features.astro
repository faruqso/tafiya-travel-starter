---
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import PlusGrid from '../ui/PlusGrid.astro';
import LogoTicker from '../ui/LogoTicker.astro';
import type { Locale } from '../../config/locales';
import type { FeaturesSection } from '../../types/content';

interface Props {
  section: FeaturesSection['value'];
  locale: Locale;
}

const { section, locale } = Astro.props;

const illustrationDefaults = [
  '/images/services/tafiya/icons/illustration-weather.svg',
  '/images/services/tafiya/icons/illustration-flights.svg',
  '/images/services/tafiya/icons/illustration-events.svg',
  '/images/services/tafiya/icons/illustration-customization.svg',
] as const;

const illustrationVariants = ['weather', 'flights', 'events', 'customization'] as const;
---

<Section variant="default" class="services">
  <Container class="services__container">
    <PlusGrid variant="services" class="services__plus" />

    <SectionHeader eyebrow={section.eyebrow} headline={section.headline} />

    {
      section.logos && section.logos.length > 0 && (
        <LogoTicker
          logos={section.logos}
          locale={locale}
          class="services__ticker"
          label={section.logoTickerLabel}
        />
      )
    }

    <div
      class="services__grid"
      data-item-count={section.items.length}
      data-reveal-group
      data-reveal-stagger="90"
    >
      {
        section.items.map((item, index) => {
          const variant = illustrationVariants[index] ?? 'weather';
          const iconSrc = illustrationDefaults[index] ?? item.icon;

          return (
            <article
              class:list={[
                'service-item',
                `service-item--${variant}`,
                item.featured && 'service-item--featured',
              ]}
              data-reveal-item
              tabindex="0"
            >
              <div class="service-item__slot">
                <div class="service-item__panel">
                  <div class:list={['service-item__icon-wrap', `service-item__icon-wrap--${variant}`]}>
                    <img
                      src={iconSrc}
                      alt=""
                      class="service-item__illustration"
                      loading="lazy"
                    />
                  </div>
                  <div class="service-item__body">
                    <h3 class="service-item__title">{item.title}</h3>
                    <p class="service-item__desc">{item.description}</p>
                  </div>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </Container>
</Section>

<style>
  .services :global(.services__container) {
    position: relative;
  }

  .services :global(.services__plus) {
    position: absolute;
    top: 0.375rem;
    right: var(--container-padding-x);
    display: none;
  }

  .services :global(.section-header) {
    margin-bottom: var(--services-header-margin-bottom);
  }

  .services :global(.services__ticker) {
    margin-bottom: var(--space-10);
  }

  .services__grid {
    display: grid;
    gap: var(--services-grid-gap);
    align-items: start;
    justify-content: center;
    padding-bottom: var(--services-grid-padding-bottom);
  }

  /* Home: 4-up row on desktop */
  .services__grid[data-item-count='4'] {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  /* Inner pages: center 1–3 cards as a group */
  .services__grid[data-item-count='1'] {
    grid-template-columns: minmax(0, var(--service-card-max-width));
  }

  .services__grid[data-item-count='2'] {
    grid-template-columns: repeat(2, minmax(0, var(--service-card-max-width)));
  }

  .services__grid[data-item-count='3'] {
    grid-template-columns: repeat(3, minmax(0, var(--service-card-max-width)));
  }

  .services__grid[data-item-count='5'],
  .services__grid[data-item-count='6'] {
    grid-template-columns: repeat(auto-fit, minmax(var(--service-card-max-width), var(--service-card-max-width)));
  }

  .service-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    outline: none;
    cursor: default;
    overflow: visible;
  }

  .service-item__slot {
    position: relative;
    width: 100%;
    max-width: var(--service-card-max-width);
    overflow: visible;
  }

  .service-item__panel {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .service-item__icon-wrap {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: var(--service-icon-wrap-width);
    height: var(--service-icon-wrap-height);
    margin-bottom: 0.125rem;
  }

  .service-item__illustration {
    display: block;
    flex-shrink: 0;
    object-fit: contain;
  }

  .service-item__icon-wrap--weather .service-item__illustration {
    width: 5.75rem;
    height: 4.875rem;
  }

  .service-item__icon-wrap--flights .service-item__illustration {
    width: var(--service-icon-wrap-width);
    height: var(--service-icon-wrap-height);
  }

  .service-item__icon-wrap--events .service-item__illustration {
    width: 4.1875rem;
    height: 4.6875rem;
  }

  .service-item__icon-wrap--customization .service-item__illustration {
    width: 4.8125rem;
    height: 4.125rem;
  }

  .service-item__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    border-radius: var(--radius-service-card);
    padding: 0 var(--space-6) var(--space-8);
    background-color: transparent;
    box-shadow: none;
    transition:
      background-color 0.35s ease,
      box-shadow 0.35s ease,
      padding 0.35s ease;
  }

  .service-item--featured .service-item__body,
  .service-item:hover .service-item__body,
  .service-item:focus-visible .service-item__body {
    padding-top: var(--space-8);
    background-color: var(--color-surface);
    box-shadow: var(--shadow-card);
  }

  .service-item:hover,
  .service-item:focus-visible,
  .service-item--featured {
    z-index: 2;
  }

  .service-item__title {
    font-family: var(--font-ui);
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    line-height: var(--leading-tight);
    color: var(--color-text-card);
    margin: 0 0 var(--space-3);
  }

  .service-item__desc {
    font-family: var(--font-body);
    font-size: var(--text-subhead);
    font-weight: var(--text-subhead-weight);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    max-width: 11.3125rem;
    margin: 0;
  }

  @media (min-width: 1024px) {
    .services :global(.services__plus) {
      display: grid;
    }
  }

  @media (max-width: 768px) {
    .services__grid,
    .services__grid[data-item-count='1'],
    .services__grid[data-item-count='2'],
    .services__grid[data-item-count='3'],
    .services__grid[data-item-count='4'],
    .services__grid[data-item-count='5'],
    .services__grid[data-item-count='6'] {
      grid-template-columns: 1fr;
      gap: var(--space-6);
      width: calc(100% + 2 * var(--space-4));
      max-width: none;
      margin-inline: calc(-1 * var(--space-4));
      padding-inline: var(--space-4);
      padding-bottom: var(--space-12);
    }

    .service-item {
      width: 100%;
      align-items: stretch;
    }

    .service-item__slot,
    .service-item__panel {
      width: 100%;
      max-width: none;
    }

    .service-item__body {
      width: 100%;
      max-width: none;
      padding-top: var(--space-8);
      background-color: var(--color-surface);
      box-shadow: var(--shadow-card);
    }

    .service-item__title {
      font-size: var(--text-lg);
    }

    .service-item__desc {
      max-width: none;
    }
  }

  @media (max-width: 1100px) and (min-width: 769px) {
    .services__grid[data-item-count='4'] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .services__grid[data-item-count='3'] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .services__grid {
      gap: var(--space-10);
    }
  }

  @media (max-width: 1100px) {
    .services :global(.services__plus) {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .service-item__body {
      transition: none;
    }
  }
</style>
