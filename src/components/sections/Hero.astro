---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import type { Locale } from '../../config/locales';
import { localizeHref } from '../../lib/i18n';
import { heroButtonVariant } from '../../lib/button-variant';
import type { HeroSection } from '../../types/content';

interface Props {
  section: HeroSection['value'];
  locale: Locale;
}

const { section, locale } = Astro.props;
const isCompact = section.variant === 'compact';
const isFull = !isCompact;

const headlineLines = section.headline.split('\n').map((line) => line.trim()).filter(Boolean);
const highlightWord = section.highlightWord?.trim();
const primaryButton = section.buttons?.[0];
const playDemoLabel = section.playDemoLabel ?? 'Play Demo';
const playDemoHref = section.playDemoHref ?? '#';

function renderLineWithHighlight(line: string) {
  if (!highlightWord || !line.includes(highlightWord)) {
    return line;
  }

  const parts = line.split(highlightWord);
  return parts.flatMap((part, index) => {
    const nodes: Array<{ type: 'text' | 'highlight'; value: string }> = [];
    if (part) nodes.push({ type: 'text', value: part });
    if (index < parts.length - 1) nodes.push({ type: 'highlight', value: highlightWord });
    return nodes;
  });
}
---

{
  isFull ? (
    <section class="hero hero--tafiya" data-hero-parallax>
      <div class="hero__decore" aria-hidden="true">
        <img
          class="hero__decore-pink"
          src="/images/heroes/tafiya/decore-pink.svg"
          alt=""
          data-parallax-layer
          data-parallax-speed="0.08"
        />
        <img
          class="hero__decore-cream"
          src="/images/heroes/tafiya/decore-hero.svg"
          alt=""
          data-parallax-layer
          data-parallax-speed="0.14"
        />
      </div>

      <Container class="hero__container">
        <div class="hero__layout">
          <div class="hero__copy" data-parallax-layer data-parallax-speed="0.22">
            {section.eyebrow && <p class="hero__eyebrow">{section.eyebrow}</p>}

            <h1 class="hero__headline">
              {headlineLines.map((line) => {
                const segments = renderLineWithHighlight(line);
                return (
                  <span class="hero__headline-line">
                    {Array.isArray(segments)
                      ? segments.map((segment) =>
                          segment.type === 'highlight' ? (
                            <span class="hero__highlight">
                              {segment.value}
                              <img
                                class="hero__highlight-underline"
                                src="/images/heroes/tafiya/headline-underline.svg"
                                alt=""
                                width="385"
                                height="12"
                              />
                            </span>
                          ) : (
                            segment.value
                          ),
                        )
                      : segments}
                  </span>
                );
              })}
            </h1>

            {section.subheadline && <p class="hero__subheadline">{section.subheadline}</p>}

            <div class="hero__actions">
              {primaryButton && (
                <Button
                  href={localizeHref(primaryButton.href, locale)}
                  label={primaryButton.label}
                  variant="primary"
                  size="lg"
                  class="hero__cta"
                />
              )}

              {(section.playDemoLabel || section.showPlayDemo !== false) && (
                <a href={localizeHref(playDemoHref, locale)} class="hero__play">
                  <span class="hero__play-icon" aria-hidden="true">
                    <svg class="hero__play-triangle" viewBox="0 0 12 13" fill="none" aria-hidden="true">
                      <path d="M11.25 6.5L0 13V0L11.25 6.5Z" fill="white" />
                    </svg>
                  </span>
                  <span class="hero__play-label">{playDemoLabel}</span>
                </a>
              )}
            </div>
          </div>

          <div class="hero__visual" aria-hidden="true" data-parallax-layer data-parallax-speed="0.32">
            <img
              class="hero__plane hero__plane--left"
              src="/images/heroes/tafiya/plane.svg"
              alt=""
              width="167"
              height="154"
              data-parallax-layer
              data-parallax-speed="0.38"
              data-parallax-x-speed="0.1"
            />
            <img
              class="hero__plane hero__plane--right"
              src="/images/heroes/tafiya/plane.svg"
              alt=""
              width="167"
              height="154"
              data-parallax-layer
              data-parallax-speed="0.44"
              data-parallax-x-speed="0.16"
            />
            <img
              class="hero__traveller-photo"
              src="/images/heroes/tafiya/traveller.png"
              alt=""
              width="765"
              height="764"
              loading="eager"
              fetchpriority="high"
              decoding="sync"
            />
          </div>
        </div>
      </Container>
    </section>
  ) : (
    <section class="hero hero--compact">
      {
        section.image && (
          <div class="hero__bg" aria-hidden="true">
            <img src={section.image} alt="" />
          </div>
        )
      }
      <div class="hero__overlay" aria-hidden="true" />
      <div class="hero__content hero__content--compact">
        <Container narrow>
          {section.eyebrow && <p class="hero__eyebrow hero__eyebrow--compact">{section.eyebrow}</p>}
          <h1 class="hero__headline hero__headline--compact">{section.headline}</h1>
          {section.subheadline && (
            <p class="hero__subheadline hero__subheadline--compact">{section.subheadline}</p>
          )}
          {
            section.buttons && section.buttons.length > 0 && (
              <div class="hero__actions hero__actions--compact">
                {section.buttons.map((btn) => (
                  <Button
                    href={localizeHref(btn.href, locale)}
                    label={btn.label}
                    variant={heroButtonVariant(btn.variant)}
                    size="lg"
                    class="hero__cta"
                  />
                ))}
              </div>
            )
          }
        </Container>
      </div>
    </section>
  )
}

<style>
  /* ── Tafiya full hero (Figma 96:1481 @ 1440×869) ── */
  .hero--tafiya {
    position: relative;
    overflow-x: clip;
    background-color: transparent;
    padding-block: 2.5rem 4rem;
    min-height: var(--hero-min-height);
  }

  [data-parallax-layer] {
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce), (max-width: 768px) {
    [data-parallax-layer] {
      will-change: auto;
      transform: none !important;
      --parallax-y: 0px !important;
      --parallax-x: 0px !important;
    }

    .hero__visual {
      opacity: 1 !important;
      --hero-visual-opacity: 1 !important;
    }
  }

  /* Page-level blobs sit behind content but visible through transparent header */
  .hero__decore {
    position: absolute;
    inset: 0;
    top: calc(-1 * var(--header-height));
    pointer-events: none;
    z-index: 0;
  }

  /* Pink ellipse: x=-420 y=-59.84, 478.9×496.9 */
  .hero__decore-pink {
    position: absolute;
    top: -0.5rem;
    left: -29.17%;
    width: 33.26%;
    height: auto;
    display: block;
    transform: translate3d(0, var(--parallax-y, 0px), 0);
  }

  /* Cream blob: x=736 y=-149, 766.3×872.6 — extends to traveller’s legs */
  .hero__decore-cream {
    position: absolute;
    top: -9.3125rem;
    right: -6%;
    left: auto;
    width: 58%;
    height: auto;
    display: block;
    transform: scale(1.22) translate3d(0, var(--parallax-y, 0px), 0);
    transform-origin: top right;
  }

  .hero--tafiya :global(.hero__container) {
    position: relative;
    z-index: 1;
  }

  .hero__layout {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
    /* Must live on this element — scoped styles don't reach Container's root */
    padding-top: calc(var(--header-height) + 4rem);
  }

  .hero__copy {
    position: relative;
    z-index: 2;
    max-width: var(--hero-copy-max);
    transform: translate3d(0, var(--parallax-y, 0px), 0);
  }

  .hero--tafiya .hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-eyebrow);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    margin-bottom: var(--space-8);
  }

  .hero--tafiya .hero__headline {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 5.5vw, var(--text-hero));
    font-weight: var(--font-weight-bold);
    line-height: var(--leading-hero);
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin-bottom: var(--space-10);
    max-width: var(--hero-lead-max);
  }

  .hero__headline-line {
    display: block;
  }

  .hero__highlight {
    position: relative;
    display: inline-block;
  }

  .hero__highlight-underline {
    position: absolute;
    left: 50%;
    bottom: 0.05em;
    width: min(24rem, 115%);
    max-width: var(--hero-subcopy-max);
    height: auto;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .hero--tafiya .hero__subheadline {
    font-family: var(--font-body);
    font-size: var(--text-subhead);
    font-weight: var(--text-subhead-weight);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    margin-bottom: var(--space-10);
    max-width: var(--hero-actions-max);
  }

  .hero--tafiya .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-10);
  }

  .hero__cta {
    min-width: 10.625rem;
    border-radius: 0.625rem;
    font-weight: var(--font-weight-medium);
    box-shadow: var(--shadow-cta);
  }

  .hero__cta--ghost {
    box-shadow: none;
  }

  .hero__play {
    display: inline-flex;
    align-items: center;
    gap: var(--space-5);
    color: var(--color-text-secondary);
    transition: color var(--transition-base);
  }

  .hero__play:hover {
    color: var(--color-text);
  }

  .hero__play-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    flex-shrink: 0;
    border-radius: var(--radius-full);
    background-color: var(--color-accent);
    box-shadow: var(--shadow-play-btn);
  }

  .hero__play-triangle {
    width: 0.703125rem;
    height: 0.8125rem;
    margin-inline-start: 0.125rem;
  }

  .hero__play-label {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--font-weight-medium);
  }

  /* Traveller frame 765×764 + planes (Figma Image group) */
  .hero__visual {
    position: relative;
    width: min(47.8125rem, 100%);
    aspect-ratio: 765 / 764;
    margin-inline: auto;
    margin-top: var(--space-8);
    flex-shrink: 0;
    overflow: visible;
    opacity: var(--hero-visual-opacity, 1);
    transform: translate3d(0, var(--parallax-y, 0px), 0);
    transition: opacity 0.45s ease-out;
    will-change: opacity, transform;
  }

  .hero__traveller-photo {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: contain;
    object-position: center bottom;
  }

  .hero__plane {
    position: absolute;
    width: 21.31%;
    height: auto;
    pointer-events: none;
    transform: translate3d(var(--parallax-x, 0px), var(--parallax-y, 0px), 0);
  }

  /* plane @ 697.91,160.89 — sits on cream/white seam, shoulder height */
  .hero__plane--left {
    top: 12%;
    left: 12%;
    z-index: 2;
  }

  /* plane @ 1181.91,207.89 — behind traveller */
  .hero__plane--right {
    top: 13.5%;
    left: 80.6%;
    z-index: 0;
  }

  @media (max-width: 1100px) {
    .hero__layout {
      align-items: center;
      text-align: center;
    }

    .hero__copy {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      max-width: var(--content-max-sm);
      margin-inline: auto;
      text-align: center;
      padding-right: 0;
    }

    .hero--tafiya .hero__eyebrow,
    .hero--tafiya .hero__headline,
    .hero--tafiya .hero__subheadline {
      text-align: center;
    }

    .hero--tafiya .hero__headline {
      margin-inline: auto;
    }

    .hero__headline-line {
      white-space: normal;
    }

    .hero--tafiya .hero__subheadline {
      margin-inline: auto;
    }

    .hero--tafiya .hero__actions {
      justify-content: center;
    }

    .hero__visual {
      position: relative;
      top: auto;
      right: auto;
      width: min(var(--content-max-sm), 100%);
      height: auto;
      aspect-ratio: 765 / 764;
      margin-top: var(--space-10);
      margin-inline: auto;
    }
  }

  @media (min-width: 1100px) {
    .hero--tafiya {
      padding-block: 3rem 5rem;
      min-height: var(--hero-min-height-desktop);
    }

    .hero__layout {
      display: grid;
      grid-template-columns: minmax(0, 39.375rem) minmax(0, 1fr);
      align-items: start;
      text-align: start;
      min-height: 47.75rem;
      padding-top: calc(var(--header-height) + 5.5rem);
    }

    .hero__decore-cream {
      right: -10%;
      width: 56%;
      transform: scale(1.3) translate3d(0, var(--parallax-y, 0px), 0);
    }

    .hero__copy {
      grid-column: 1;
      grid-row: 1;
      display: block;
      max-width: var(--hero-copy-max-lg);
      width: 100%;
      padding-inline-end: var(--space-8);
      margin-inline: 0;
      text-align: start;
    }

    .hero--tafiya .hero__eyebrow,
    .hero--tafiya .hero__headline,
    .hero--tafiya .hero__subheadline {
      text-align: start;
    }

    .hero--tafiya .hero__actions {
      justify-content: flex-start;
    }

    .hero__headline-line {
      white-space: nowrap;
    }

    .hero__visual {
      grid-column: 2;
      grid-row: 1;
      position: relative;
      top: 3.5rem;
      justify-self: end;
      width: 47.8125rem;
      height: 47.75rem;
      margin: 0;
      margin-inline-end: -4rem;
      aspect-ratio: auto;
      overflow: visible;
    }
  }

  /* ── Compact hero (inner pages) ── */
  .hero--compact {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--hero-compact-min-height);
    color: var(--color-text-inverse);
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
  }

  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      var(--color-hero-overlay-start) 0%,
      var(--color-hero-overlay-mid) 50%,
      var(--color-hero-overlay-end) 100%
    );
  }

  .hero__content--compact {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-block: var(--space-16);
  }

  .hero__content--compact :global(.container) {
    text-align: center;
  }

  .hero--compact .hero__eyebrow--compact {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-hero-subtext);
    margin-bottom: var(--space-4);
  }

  .hero--compact .hero__headline--compact {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-inverse);
    margin-bottom: var(--space-6);
    text-wrap: balance;
  }

  .hero--compact .hero__subheadline--compact {
    color: var(--color-hero-subtext-strong);
    margin: 0 auto var(--space-8);
    max-width: var(--content-max-sm);
  }

  .hero--compact .hero__actions--compact {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
  }

  @media (max-width: 768px) {
    .hero--compact {
      min-height: 36vh;
    }

    .hero--tafiya {
      min-height: auto;
      padding-block: 0 var(--space-12);
    }

    .hero__layout {
      padding-top: calc(var(--header-height) + 3rem);
    }

    .hero--tafiya .hero__eyebrow {
      margin-bottom: var(--space-4);
    }

    .hero--tafiya .hero__headline {
      font-size: var(--text-hero);
      margin-bottom: var(--space-6);
    }

    .hero__headline-line {
      white-space: normal;
    }

    .hero--tafiya .hero__subheadline {
      font-size: var(--text-subhead);
      font-weight: var(--text-subhead-weight);
      line-height: var(--leading-normal);
      margin-bottom: var(--space-8);
    }

    .hero--tafiya .hero__actions {
      gap: var(--space-6);
    }

    .hero--compact .hero__headline--compact {
      font-size: var(--text-3xl);
    }

    .hero__plane {
      width: 18%;
    }

    .hero__decore-cream {
      right: -10%;
      width: 68%;
      transform: scale(1.15) translate3d(0, var(--parallax-y, 0px), 0);
    }
  }
</style>
