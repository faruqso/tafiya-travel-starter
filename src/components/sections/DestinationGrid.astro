---
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import type { DestinationGridSection } from '../../types/content';

interface Props {
  section: DestinationGridSection['value'];
}

const { section } = Astro.props;
---

<Section variant="default" class="destinations">
  <Container class="destinations__container">
    <SectionHeader eyebrow={section.eyebrow} headline={section.headline} />

    <div class="destinations__grid">
      {
        section.destinations.map((dest) => (
          <a href={dest.href} class="destinations__link">
            <article class="dest-card">
              <div class="dest-card__image-wrap">
                <img src={dest.image} alt={dest.name} class="dest-card__image" loading="lazy" />
              </div>
              <div class="dest-card__footer">
                <div class="dest-card__row">
                  <span class="dest-card__name">{dest.name}</span>
                  <span class="dest-card__price">{dest.priceFrom}</span>
                </div>
                {dest.duration && (
                  <div class="dest-card__meta">
                    <img
                      src="/images/destinations/tafiya/navigation.svg"
                      alt=""
                      class="dest-card__nav-icon"
                      width="20"
                      height="20"
                    />
                    <span class="dest-card__duration">{dest.duration}</span>
                  </div>
                )}
              </div>
            </article>
          </a>
        ))
      }
    </div>

    <img
      src="/images/destinations/tafiya/decore.svg"
      alt=""
      class="destinations__deco"
      aria-hidden="true"
    />
  </Container>
</Section>

<style>
  .destinations :global(.destinations__container) {
    position: relative;
  }

  .destinations__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-12);
    align-items: start;
  }

  .destinations__link {
    position: relative;
    color: inherit;
    text-decoration: none;
  }

  .dest-card {
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    background-color: var(--color-surface);
    transition: transform var(--transition-base);
  }

  .destinations__link:hover .dest-card {
    transform: translateY(-4px);
  }

  .dest-card__image-wrap {
    aspect-ratio: 314 / 457;
    overflow: hidden;
  }

  .dest-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .dest-card__footer {
    padding: var(--space-5) var(--space-5) var(--space-6);
    min-height: 8.125rem;
  }

  .dest-card__row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .dest-card__name,
  .dest-card__price {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-medium);
    line-height: 1.245;
    color: var(--color-text-muted);
  }

  .dest-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .dest-card__nav-icon {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
  }

  .dest-card__duration {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--font-weight-medium);
    line-height: 1.245;
    color: var(--color-text-muted);
  }

  .destinations__deco {
    position: absolute;
    top: 55%;
    right: calc(var(--container-padding-x) - 2rem);
    width: 6rem;
    height: auto;
    pointer-events: none;
    z-index: 0;
  }

  @media (max-width: 1024px) {
    .destinations__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }

    .destinations__deco {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .destinations__grid {
      grid-template-columns: 1fr;
      max-width: 19.625rem;
      margin-inline: auto;
    }
  }
</style>
