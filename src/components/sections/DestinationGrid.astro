---
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import Button from '../ui/Button.astro';
import type { Locale } from '../../config/locales';
import { localizeHref } from '../../lib/i18n';
import type { DestinationGridSection } from '../../types/content';

interface Props {
  section: DestinationGridSection['value'];
  locale: Locale;
}

const { section, locale } = Astro.props;
const ctaLabel = section.ctaLabel ?? 'View destinations';
const ctaHref = localizeHref(section.ctaHref ?? '/destinations', locale);
---

<Section variant="default" class="destinations">
  <Container class="destinations__container">
    <SectionHeader eyebrow={section.eyebrow} headline={section.headline} />

    <div class="destinations__grid" data-reveal-group data-reveal-stagger="110">
      {
        section.destinations.map((dest) => (
          <a href={localizeHref(dest.href, locale)} class="destinations__link" data-reveal-item>
            <article class="dest-card">
              <div class="dest-card__image-wrap">
                <img src={dest.image} alt={dest.name} class="dest-card__image" loading="lazy" />
              </div>
              <div class="dest-card__footer">
                <div class="dest-card__row">
                  <span class="dest-card__name">{dest.name}</span>
                  <span class="dest-card__price">{dest.priceFrom}</span>
                </div>
                {dest.duration && (
                  <div class="dest-card__meta">
                    <img
                      src="/images/destinations/tafiya/navigation.svg"
                      alt=""
                      class="dest-card__nav-icon"
                      width="20"
                      height="20"
                    />
                    <span class="dest-card__duration">{dest.duration}</span>
                  </div>
                )}
              </div>
            </article>
          </a>
        ))
      }
    </div>

    <div class="destinations__cta" data-reveal>
      <Button href={ctaHref} label={ctaLabel} variant="primary" size="lg" />
    </div>
  </Container>
</Section>

<style>
  .destinations :global(.destinations__container) {
    position: relative;
  }

  .destinations__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-12);
    align-items: start;
  }

  .destinations__link {
    position: relative;
    display: block;
    width: 100%;
    color: inherit;
    text-decoration: none;
  }

  .dest-card {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: var(--card-height-catalog);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    background-color: var(--color-surface);
    transition: transform var(--transition-base);
  }

  .destinations__link:hover .dest-card {
    transform: translateY(-4px);
  }

  .dest-card__image-wrap {
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .dest-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .dest-card__footer {
    flex-shrink: 0;
    padding: var(--space-5) var(--space-5) var(--space-6);
  }

  .dest-card__row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .dest-card__name,
  .dest-card__price {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-medium);
    line-height: var(--leading-card);
    color: var(--color-text-muted);
  }

  .dest-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .dest-card__nav-icon {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
  }

  .dest-card__duration {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--font-weight-medium);
    line-height: var(--leading-card);
    color: var(--color-text-muted);
  }

  .destinations__cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-12);
  }

  @media (max-width: 768px) {
    .destinations__grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
      width: calc(100% + 2 * var(--space-4));
      max-width: none;
      margin-inline: calc(-1 * var(--space-4));
      padding-inline: var(--space-4);
    }

    .dest-card {
      border-radius: var(--radius-lg);
    }

    .dest-card__name,
    .dest-card__price {
      font-size: var(--text-base);
    }
  }

  @media (max-width: 1024px) and (min-width: 769px) {
    .destinations__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }
  }
</style>
