---
import Section from '../ui/Section.astro';
import LogoTicker from '../ui/LogoTicker.astro';
import type { Locale } from '../../config/locales';
import type { LogoCloudSection } from '../../types/content';

interface Props {
  section: LogoCloudSection['value'];
  locale: Locale;
}

const { section, locale } = Astro.props;
---

<Section variant="default" compact class="logo-cloud">
  <LogoTicker logos={section.logos} locale={locale} />
</Section>

<style>
  .logo-cloud {
    overflow: hidden;
  }
</style>
