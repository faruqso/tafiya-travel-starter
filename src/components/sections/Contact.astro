---
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import Heading from '../ui/Heading.astro';
import Text from '../ui/Text.astro';
import Card from '../ui/Card.astro';
import Button from '../ui/Button.astro';
import FormField from '../ui/FormField.astro';
import type { ContactSection } from '../../types/content';
import { contactPurposeConfigs, resolveContactPurpose } from '../../lib/contact-purpose';

interface Props {
  section: ContactSection['value'];
}

const { section } = Astro.props;
const purpose = resolveContactPurpose(section.purpose);
const formConfig = contactPurposeConfigs[purpose];
const sectionId = purpose === 'careers' ? 'apply' : purpose !== 'general' ? purpose : undefined;
---

<Section variant="muted" id={sectionId}>
  <Container>
    <div class="contact">
      <div class="contact__info">
        {section.eyebrow && <p class="contact__eyebrow">{section.eyebrow}</p>}
        <Heading as="h2" size="lg">{section.headline}</Heading>
        {purpose !== 'general' && <p class="contact__purpose">{formConfig.label}</p>}
        {section.subheadline && <Text variant="lead">{section.subheadline}</Text>}

        <ul class="contact__details">
          <li>
            <span class="contact__label">Email</span>
            <a href={`mailto:${section.email}`}>{section.email}</a>
          </li>
          {
            section.phone && (
              <li>
                <span class="contact__label">Phone</span>
                <a href={`tel:${section.phone.replace(/\s/g, '')}`}>{section.phone}</a>
              </li>
            )
          }
          {
            section.address && (
              <li>
                <span class="contact__label">Address</span>
                <span>{section.address}</span>
              </li>
            )
          }
        </ul>
      </div>

      <Card>
        {section.formNote && <Text variant="muted" class="contact__note">{section.formNote}</Text>}
        <form
          class="form-grid contact__form"
          data-json-form
          data-endpoint="/api/contact"
          data-success-message={formConfig.successMessage}
          novalidate
        >
          <input type="hidden" name="purpose" value={purpose} />
          {
            formConfig.fields.map((field) => (
              <FormField label={field.label} optional={!field.required}>
                {
                  field.type === 'textarea' ? (
                    <textarea
                      name={field.name}
                      rows={field.rows ?? 4}
                      placeholder={field.placeholder}
                      required={field.required}
                    />
                  ) : (
                    <input
                      type={field.type}
                      name={field.name}
                      placeholder={field.placeholder}
                      required={field.required}
                    />
                  )
                }
              </FormField>
            ))
          }
          <Button type="submit" label={formConfig.submitLabel} variant="primary" size="lg" class="form-submit" />
          <p class="form-status" data-form-status role="status" aria-live="polite"></p>
        </form>
      </Card>
    </div>
  </Container>
</Section>

<style>
  .contact {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 28rem);
    gap: var(--space-12);
    align-items: start;
  }

  .contact__eyebrow {
    font-size: var(--text-eyebrow);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-brand);
    margin-bottom: var(--space-3);
  }

  .contact__purpose {
    margin: calc(-1 * var(--space-2)) 0 var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-brand);
  }

  .contact__details {
    margin-top: var(--space-8);
    display: grid;
    gap: var(--space-4);
  }

  .contact__label {
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-1);
  }

  .contact__details a {
    color: var(--color-brand);
    font-weight: var(--font-weight-medium);
  }

  .contact__details a:hover {
    text-decoration: underline;
  }

  .contact__note {
    margin-bottom: var(--space-6);
  }

  @media (max-width: 900px) {
    .contact {
      grid-template-columns: 1fr;
    }
  }
</style>
