---
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import Heading from '../ui/Heading.astro';
import Text from '../ui/Text.astro';
import Button from '../ui/Button.astro';
import type { Locale } from '../../config/locales';
import { localizeHref } from '../../lib/i18n';
import type { CtaSection } from '../../types/content';
import { buttonVariantOnDark } from '../../lib/button-variant';

interface Props {
  section: CtaSection['value'];
  locale: Locale;
}

const { section, locale } = Astro.props;
---

<Section variant="dark">
  <Container>
    <div class="cta">
      <Heading as="h2" size="lg" class="text-balance">{section.headline}</Heading>
      {section.subheadline && <Text variant="lead" class="cta__sub">{section.subheadline}</Text>}
      {
        section.buttons && section.buttons.length > 0 && (
          <div class="cta__actions">
            {section.buttons.map((btn) => (
              <Button href={localizeHref(btn.href, locale)} label={btn.label} variant={buttonVariantOnDark(btn.variant)} size="lg" />
            ))}
          </div>
        )
      }
    </div>
  </Container>
</Section>

<style>
  .cta {
    text-align: center;
    max-width: var(--content-max-sm);
    margin-inline: auto;
  }

  .cta__sub {
    margin-top: var(--space-4);
    color: var(--color-cta-subtext);
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }
</style>
