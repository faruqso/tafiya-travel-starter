---
import Hero from './sections/Hero.astro';
import DestinationGrid from './sections/DestinationGrid.astro';
import Features from './sections/Features.astro';
import BookTrip from './sections/BookTrip.astro';
import Testimonials from './sections/Testimonials.astro';
import LogoCloud from './sections/LogoCloud.astro';
import Subscribe from './sections/Subscribe.astro';
import Stats from './sections/Stats.astro';
import TextBlock from './sections/TextBlock.astro';
import Cta from './sections/Cta.astro';
import Contact from './sections/Contact.astro';
import AppDownload from './sections/AppDownload.astro';
import BookingForm from './sections/BookingForm.astro';
import type { Locale } from '../config/locales';
import type { PageSection } from '../types/content';

interface Props {
  sections: PageSection[];
  locale: Locale;
}

const { sections, locale } = Astro.props;
---

{
  sections.map((section) => {
    switch (section.discriminant) {
      case 'hero':
        return <Hero section={section.value} locale={locale} />;
      case 'destinationGrid':
        return <DestinationGrid section={section.value} locale={locale} />;
      case 'features':
        return <Features section={section.value} locale={locale} />;
      case 'bookTrip':
        return <BookTrip section={section.value} />;
      case 'testimonials':
        return <Testimonials section={section.value} />;
      case 'logoCloud':
        return <LogoCloud section={section.value} locale={locale} />;
      case 'subscribe':
        return <Subscribe section={section.value} />;
      case 'stats':
        return <Stats section={section.value} />;
      case 'textBlock':
        return <TextBlock section={section.value} />;
      case 'cta':
        return <Cta section={section.value} locale={locale} />;
      case 'contact':
        return <Contact section={section.value} />;
      case 'appDownload':
        return <AppDownload section={section.value} />;
      case 'bookingForm':
        return <BookingForm section={section.value} locale={locale} />;
      default:
        return null;
    }
  })
}
