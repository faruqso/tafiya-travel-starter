---
import BrandLogo from '../ui/BrandLogo.astro';
import Button from '../ui/Button.astro';
import TextNavLink from '../ui/TextNavLink.astro';
import LanguageSwitcher from '../ui/LanguageSwitcher.astro';
import type { Locale } from '../../config/locales';
import { getLocalizedPath } from '../../lib/i18n';
import { isNavLinkActive } from '../../lib/nav-active';
import type { SiteSettings } from '../../types/content';
import { getAppLabels } from '../../i18n/app';

interface Props {
  site: SiteSettings;
  locale: Locale;
  currentPath?: string;
  transparent?: boolean;
}

const { site, locale, currentPath = Astro.url.pathname, transparent = false } = Astro.props;
const app = getAppLabels(locale);
---

<header class:list={['nav', transparent && 'nav--transparent']}>
  <div class="nav__inner">
    <BrandLogo size="nav" src={site.logo} href={getLocalizedPath('/', locale)} />

    <div id="nav-menu" class="nav__menu">
      <nav class="nav__links" aria-label="Main navigation">
        {
          site.navLinks.map((link) => {
            const href = getLocalizedPath(link.href, locale);
            const isActive = isNavLinkActive(currentPath, link.href);

            return (
              <TextNavLink
                href={href}
                label={link.label}
                variant="header"
                active={isActive}
                class="nav__link"
              />
            );
          })
        }
      </nav>

      <div class="nav__actions">
        <div class="nav__auth-guest" data-nav-guest>
          <TextNavLink
            href={getLocalizedPath('/login', locale)}
            label={site.loginLabel ?? 'Login'}
            variant="header-login"
            class="nav__login"
          />
          <Button
            href={getLocalizedPath('/signup', locale)}
            label={site.signupLabel ?? 'Sign up'}
            variant="nav-signup"
            size="md"
            class="nav__signup"
          />
        </div>
        <div class="nav__auth-user" data-nav-authed hidden>
          <span class="nav__user" data-nav-user></span>
          <Button type="button" label={app.signOut} variant="secondary" size="sm" class="nav__logout" mockLogout />
        </div>
        <div class="nav__lang nav__lang--desktop">
          <LanguageSwitcher locale={locale} currentPath={currentPath} />
        </div>
      </div>
    </div>

    <div class="nav__header-tools">
      <div class="nav__lang nav__lang--compact">
        <LanguageSwitcher locale={locale} currentPath={currentPath} />
      </div>

      <button
        type="button"
        class="nav__toggle"
        aria-expanded="false"
        aria-controls="nav-menu"
        aria-label="Open menu"
      >
        <span class="nav__toggle-bar"></span>
        <span class="nav__toggle-bar"></span>
        <span class="nav__toggle-bar"></span>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector('.nav__toggle');
  const menu = document.querySelector('#nav-menu');

  const setMenuOpen = (open: boolean) => {
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    menu?.classList.toggle('is-open', open);
    document.body.classList.toggle('nav-menu-open', open);
  };

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    setMenuOpen(!open);
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && menu?.classList.contains('is-open')) {
      setMenuOpen(false);
    }
  });

  const transparentNav = document.querySelector('.nav--transparent');
  if (transparentNav) {
    const syncNav = () => {
      transparentNav.classList.toggle('nav--scrolled', window.scrollY > 12);
    };
    syncNav();
    window.addEventListener('scroll', syncNav, { passive: true });
  }
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .nav:not(.nav--transparent) {
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border-light);
    box-shadow: var(--shadow-nav);
  }

  .nav--transparent {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: none;
    background-color: transparent;
    border-bottom: 1px solid transparent;
    box-shadow: none;
  }

  .nav--transparent .nav__inner,
  .nav--transparent .nav__menu {
    background: transparent;
    background-color: transparent;
  }

  .nav--transparent.nav--scrolled {
    background-color: var(--color-surface);
    border-bottom-color: var(--color-border-light);
    box-shadow: var(--shadow-nav);
  }

  .nav--transparent.nav--scrolled .nav__inner,
  .nav--transparent.nav--scrolled .nav__menu {
    background-color: transparent;
  }

  .nav--transparent .nav__menu.is-open {
    background: var(--color-surface);
    border-top-color: var(--color-border-light);
  }

  .nav__inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--space-3) var(--container-padding-x);
    min-height: var(--header-height);
  }

  .nav__header-tools {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .nav__lang--desktop {
    display: none;
  }

  .nav__toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.3125rem;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    cursor: pointer;
    transition:
      background-color var(--transition-slow),
      border-color var(--transition-slow),
      box-shadow var(--transition-slow);
  }

  .nav__toggle:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-sm);
  }

  .nav__toggle[aria-expanded='true'] {
    border-color: var(--color-accent);
    background: var(--color-nav-toggle-active);
  }

  .nav__toggle-bar {
    display: block;
    width: 1.25rem;
    height: 2px;
    background: var(--color-nav-text);
    border-radius: 1px;
    transform-origin: center;
    transition:
      transform 0.32s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease,
      width 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav__toggle[aria-expanded='true'] .nav__toggle-bar:nth-child(1) {
    transform: translateY(0.4375rem) rotate(45deg);
  }

  .nav__toggle[aria-expanded='true'] .nav__toggle-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .nav__toggle[aria-expanded='true'] .nav__toggle-bar:nth-child(3) {
    transform: translateY(-0.4375rem) rotate(-45deg);
  }

  .nav__menu {
    display: flex;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    flex-direction: column;
    gap: 0;
    padding: var(--space-2) var(--container-padding-x) var(--space-6);
    background: var(--color-surface);
    border-top: 1px solid var(--color-border-light);
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    box-shadow: var(--shadow-lg);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-0.5rem) scale(0.98);
    transform-origin: top center;
    pointer-events: none;
    transition:
      opacity 0.32s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.32s cubic-bezier(0.4, 0, 0.2, 1),
      visibility 0.32s;
  }

  .nav__menu.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .nav__links {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-block: var(--space-2);
  }

  .nav__link,
  .nav__login {
    /* Layout hooks for mobile menu stagger; styles from .text-nav-link--* */
  }

  .nav__actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-3);
    width: 100%;
    margin-top: var(--space-4);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border-light);
  }

  .nav__auth-guest,
  .nav__auth-user {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-3);
    width: 100%;
  }

  .nav__auth-guest[hidden],
  .nav__auth-user[hidden] {
    display: none !important;
  }

  .nav__auth-user {
    align-items: center;
  }

  .nav__user {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-section);
    text-align: center;
  }

  .nav__login {
    justify-content: center;
  }

  .nav__signup {
    font-weight: var(--font-weight-semibold);
  }

  @media (max-width: 1100px) {
    .nav__menu .nav__link,
    .nav__menu .nav__login,
    .nav__menu .nav__signup {
      opacity: 0;
      transform: translateY(0.375rem);
      transition:
        opacity 0.28s cubic-bezier(0.4, 0, 0.2, 1),
        transform 0.28s cubic-bezier(0.4, 0, 0.2, 1),
        color var(--transition-base),
        background-color var(--transition-base),
        border-color var(--transition-base),
        box-shadow var(--transition-base);
    }

    .nav__menu.is-open .nav__link {
      opacity: 1;
      transform: translateY(0);
    }

    .nav__menu.is-open .nav__link:nth-child(1) {
      transition-delay: 0.04s;
    }

    .nav__menu.is-open .nav__link:nth-child(2) {
      transition-delay: 0.08s;
    }

    .nav__menu.is-open .nav__link:nth-child(3) {
      transition-delay: 0.12s;
    }

    .nav__menu.is-open .nav__link:nth-child(4) {
      transition-delay: 0.16s;
    }

    .nav__menu.is-open .nav__login {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0.2s;
    }

    .nav__menu.is-open .nav__signup {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0.24s;
    }

    .nav__menu:not(.is-open) .nav__link,
    .nav__menu:not(.is-open) .nav__login,
    .nav__menu:not(.is-open) .nav__signup {
      transition-delay: 0s;
    }
  }

  :global(body.nav-menu-open) {
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav__toggle-bar,
    .nav__menu,
    .nav__menu .nav__link,
    .nav__menu .nav__login,
    .nav__menu .nav__signup {
      transition: none;
    }
  }

  @media (min-width: 1100px) {
    .nav__header-tools {
      display: none;
    }

    .nav__lang--desktop {
      display: block;
    }

    .nav__menu {
      position: static;
      flex: 1;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-6);
      padding: 0;
      border: none;
      border-radius: 0;
      box-shadow: none;
      background: transparent;
      opacity: 1;
      visibility: visible;
      transform: none;
      pointer-events: auto;
    }

    .nav__links {
      flex-direction: row;
      gap: 2.75rem;
      margin-inline: auto;
      padding-block: 0;
    }

    .nav__link,
    .nav__login {
      /* desktop overrides live on .text-nav-link--header* */
    }

    .nav__actions {
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: center;
      width: auto;
      margin-top: 0;
      padding-top: 0;
      border-top: none;
      gap: var(--space-4);
    }

    .nav__auth-guest,
    .nav__auth-user {
      flex-direction: row;
      align-items: center;
      width: auto;
      gap: var(--space-4);
    }

    .nav__login {
      justify-content: flex-start;
    }

    .nav__signup {
      font-size: var(--text-nav-desktop);
      font-weight: var(--font-weight-medium);
    }

    .nav__menu .nav__link,
    .nav__menu .nav__login,
    .nav__menu .nav__signup {
      opacity: 1;
      transform: none;
      transition: color var(--transition-base), border-color var(--transition-base);
    }
  }
</style>
