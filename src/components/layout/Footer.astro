---
import BrandLogo from '../ui/BrandLogo.astro';
import type { SiteSettings } from '../../types/content';

interface Props {
  site: SiteSettings;
}

const { site } = Astro.props;

const socialIcons: Record<
  string,
  { bg: string; icon?: string; size: number; iconWidth?: number; iconHeight?: number }
> = {
  Facebook: {
    bg: '/images/footer/tafiya/social-bg.svg',
    icon: '/images/footer/tafiya/facebook-icon.svg',
    size: 41,
    iconWidth: 6,
    iconHeight: 13,
  },
  Instagram: {
    bg: '/images/footer/tafiya/instagram-bg.svg',
    icon: '/images/footer/tafiya/instagram-icon.svg',
    size: 45,
    iconWidth: 16,
    iconHeight: 16,
  },
  Twitter: {
    bg: '/images/footer/tafiya/social-bg.svg',
    icon: '/images/footer/tafiya/twitter-icon.svg',
    size: 41,
    iconWidth: 16,
    iconHeight: 13,
  },
};
---

<footer class="footer">
  <div class="footer__deco" aria-hidden="true">
    <img src="/images/footer/tafiya/decore.svg" alt="" width="479" height="497" />
  </div>

  <div class="footer__inner">
    <div class="footer__brand">
      <BrandLogo size="footer" src={site.logo} />
      <p class="footer__tagline">{site.footerTagline ?? site.tagline}</p>
    </div>

    {
      site.footerColumns.map((column) => (
        <div class="footer__column">
          <p class="footer__column-title">{column.title}</p>
          <ul class="footer__links">
            {column.links.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }

    <div class="footer__outbound">
      {
        site.socialLinks.length > 0 && (
          <ul class="footer__social">
            {site.socialLinks.map((link) => {
              const config = socialIcons[link.label];
              if (!config) return null;

              return (
                <li>
                  <a
                    href={link.href}
                    class:list={['footer__social-link', `footer__social-link--${link.label.toLowerCase()}`]}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={link.label}
                  >
                    <img
                      src={config.bg}
                      alt=""
                      class="footer__social-bg"
                      width={config.size}
                      height={config.size}
                    />
                    {config.icon && (
                      <img
                        src={config.icon}
                        alt=""
                        class="footer__social-icon"
                        width={config.iconWidth}
                        height={config.iconHeight}
                      />
                    )}
                  </a>
                </li>
              );
            })}
          </ul>
        )
      }

      {site.appStoreLabel && (
        <div class="footer__apps">
          <p class="footer__apps-label">{site.appStoreLabel}</p>
          <div class="footer__store-badges">
            {site.googlePlayUrl && (
              <a href={site.googlePlayUrl} class="footer__store footer__store--google" target="_blank" rel="noopener noreferrer">
                <img src="/images/footer/tafiya/google-play-icon.svg" alt="" width="20" height="20" />
                <img src="/images/footer/tafiya/google-play-text.svg" alt="Get it on Google Play" width="54" height="15" />
              </a>
            )}
            {site.appStoreUrl && (
              <a href={site.appStoreUrl} class="footer__store footer__store--apple" target="_blank" rel="noopener noreferrer">
                <span class="footer__apple-icon" aria-hidden="true">
                  <img src="/images/footer/tafiya/apple-icon.svg" alt="" width="13" height="12" />
                  <img src="/images/footer/tafiya/apple-icon-leaf.svg" alt="" class="footer__apple-leaf" width="3" height="4" />
                </span>
                <img src="/images/footer/tafiya/app-store-text.svg" alt="Available on the Apple Store" width="54" height="17" />
              </a>
            )}
          </div>
        </div>
      )}
    </div>
  </div>

  <p class="footer__copyright">{site.copyright}</p>
</footer>

<style>
  .footer {
    position: relative;
    background-color: var(--color-surface);
    padding: 0 0 2.625rem;
    overflow: hidden;
  }

  .footer__deco {
    position: absolute;
    top: 8.5625rem;
    right: 0;
    width: 29.934rem;
    pointer-events: none;
    opacity: 0.4;
    transform: scaleY(-1) rotate(180deg);
  }

  .footer__deco img {
    display: block;
    width: 100%;
    height: auto;
  }

  .footer__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(12rem, 18.125rem) repeat(3, minmax(7rem, 11.25rem)) minmax(13rem, 1fr);
    gap: 0;
    max-width: var(--container-max);
    margin-inline: auto;
    padding: 0 var(--container-padding-x) 3.75rem;
    align-items: start;
  }

  .footer__brand {
    padding-top: 0;
  }

  .footer__tagline {
    margin-top: 2.5625rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: var(--font-weight-medium);
    line-height: 1.245;
    color: var(--color-text-muted);
    max-width: 14rem;
    white-space: pre-line;
  }

  .footer__column {
    padding-top: 1.3125rem;
  }

  .footer__column-title {
    font-family: var(--font-body);
    font-size: 1.3125rem;
    font-weight: var(--font-weight-bold);
    line-height: 1.245;
    color: var(--color-text-strong);
    margin-bottom: 3.75rem;
  }

  .footer__column:nth-child(3) .footer__column-title {
    margin-bottom: 3.625rem;
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .footer__links li + li {
    margin-top: 2.125rem;
  }

  .footer__column:nth-child(3) .footer__links li + li {
    margin-top: 2.25rem;
  }

  .footer__column:nth-child(4) .footer__links li:first-child {
    margin-top: 0;
  }

  .footer__column:nth-child(4) .footer__links li + li {
    margin-top: 2.125rem;
  }

  .footer__column:nth-child(4) .footer__links li:nth-child(2) {
    margin-top: 2.25rem;
  }

  .footer__links a {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: var(--font-weight-medium);
    line-height: 1.245;
    color: var(--color-text-muted);
    transition: color var(--transition-base);
  }

  .footer__links a:hover {
    color: var(--color-accent);
  }

  .footer__outbound {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    padding-top: 1.3125rem;
  }

  .footer__social {
    display: flex;
    align-items: center;
    gap: 1.5625rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__social-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    line-height: 0;
    text-decoration: none;
    transition: transform var(--transition-base);
  }

  .footer__social-link:hover {
    transform: translateY(-2px);
  }

  .footer__social-bg {
    display: block;
  }

  .footer__social-link--facebook,
  .footer__social-link--twitter {
    width: 2.5625rem;
    height: 2.5625rem;
  }

  .footer__social-link--instagram {
    width: 2.8125rem;
    height: 2.8125rem;
  }

  .footer__social-icon {
    position: absolute;
    inset: 0;
    margin: auto;
    display: block;
  }

  .footer__apps-label {
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: var(--font-weight-medium);
    line-height: 1.245;
    letter-spacing: 0.00625rem;
    color: var(--color-text-muted);
  }

  .footer__store-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4375rem;
  }

  .footer__store {
    display: inline-flex;
    align-items: center;
    gap: 0.3125rem;
    height: 2.1875rem;
    padding-inline: 1.0625rem;
    color: var(--color-text-on-brand);
    background: var(--color-text-strong);
    border-radius: 1.09375rem;
    text-decoration: none;
    transition: opacity var(--transition-base);
  }

  .footer__store:hover {
    opacity: 0.88;
  }

  .footer__store--google {
    width: 6.6875rem;
    padding-inline: 1.0625rem 0.75rem;
    gap: 0.3125rem;
  }

  .footer__store--apple {
    width: 6.25rem;
    padding-inline: 1.0625rem 0.625rem;
    gap: 0.3125rem;
  }

  .footer__store img {
    display: block;
    flex-shrink: 0;
  }

  .footer__apple-icon {
    position: relative;
    display: inline-flex;
    width: 0.82025rem;
    height: 0.769625rem;
    flex-shrink: 0;
  }

  .footer__apple-leaf {
    position: absolute;
    top: -0.231rem;
    right: -0.0625rem;
  }

  .footer__copyright {
    text-align: center;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: var(--font-weight-medium);
    line-height: 1.245;
    color: var(--color-text-muted);
    padding-inline: var(--container-padding-x);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
    }

    .footer__brand,
    .footer__outbound {
      grid-column: 1 / -1;
    }

    .footer__column {
      padding-top: 0;
    }

    .footer__column-title {
      margin-bottom: var(--space-6);
    }

    .footer__links li + li {
      margin-top: var(--space-4);
    }
  }

  @media (max-width: 560px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }

    .footer__deco {
      width: min(18rem, 60vw);
      top: auto;
      bottom: 6rem;
    }
  }
</style>
