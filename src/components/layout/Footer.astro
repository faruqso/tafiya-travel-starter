---
import BrandLogo from '../ui/BrandLogo.astro';
import FooterSocialIcon from '../ui/FooterSocialIcon.astro';
import StoreBadge from '../ui/StoreBadge.astro';
import TextNavLink from '../ui/TextNavLink.astro';
import type { Locale } from '../../config/locales';
import { getLocalizedPath, localizeHref } from '../../lib/i18n';
import { isNavLinkActive } from '../../lib/nav-active';
import { linkifyEmails } from '../../lib/linkify';
import type { SiteSettings } from '../../types/content';
import { siApple, siFacebook, siInstagram, siX } from 'simple-icons';
import type { SimpleIcon } from 'simple-icons';

interface Props {
  site: SiteSettings;
  locale: Locale;
  currentPath?: string;
}

const { site, locale, currentPath = Astro.url.pathname } = Astro.props;

const socialIcons: Record<string, SimpleIcon> = {
  Facebook: siFacebook,
  Instagram: siInstagram,
  Twitter: siX,
  X: siX,
};
---

<footer class="footer">
  <div class="footer__deco" aria-hidden="true">
    <img src="/images/footer/tafiya/decore.svg" alt="" width="479" height="497" />
  </div>

  <div class="footer__inner">
    <div class="footer__brand">
      <BrandLogo size="footer" src={site.logo} href={getLocalizedPath('/', locale)} />
      <p class="footer__tagline">{site.footerTagline ?? site.tagline}</p>
    </div>

    {
      site.footerColumns.map((column) => (
        <div class="footer__column">
          <p class="footer__column-title">{column.title}</p>
          <ul class="footer__links">
            {column.links.map((link) => {
              const href = localizeHref(link.href, locale);
              const isActive = isNavLinkActive(currentPath, link.href);

              return (
              <li>
                <TextNavLink
                  href={href}
                  label={link.label}
                  variant="footer"
                  active={isActive}
                />
              </li>
              );
            })}
          </ul>
        </div>
      ))
    }

    <div class="footer__outbound">
      {
        site.socialLinks.length > 0 && (
          <ul class="footer__social">
            {site.socialLinks.map((link) => {
              const icon = socialIcons[link.label];
              if (!icon) return null;

              return (
                <li>
                  <FooterSocialIcon icon={icon} label={link.label} href={link.href} />
                </li>
              );
            })}
          </ul>
        )
      }

      {site.appStoreLabel && (
        <div class="footer__apps">
          <p class="footer__apps-label">{site.appStoreLabel}</p>
          <div class="footer__store-badges">
            {site.googlePlayUrl && (
              <StoreBadge
                href={site.googlePlayUrl}
                store="google"
                eyebrow="GET IT ON"
                title="Google Play"
              />
            )}
            {site.appStoreUrl && (
              <StoreBadge
                href={site.appStoreUrl}
                store="apple"
                icon={siApple}
                eyebrow="Download on the"
                title="App Store"
              />
            )}
          </div>
        </div>
      )}
    </div>
  </div>

  <p class="footer__copyright" set:html={linkifyEmails(site.copyright)} />
</footer>

<style>
  .footer {
    position: relative;
    background-color: var(--color-surface);
    padding: 0 0 var(--footer-inner-padding-bottom);
    overflow: hidden;
  }

  .footer__deco {
    position: absolute;
    top: var(--footer-deco-top);
    right: 0;
    width: var(--footer-deco-width);
    pointer-events: none;
    opacity: 0.4;
    transform: scaleY(-1) rotate(180deg);
  }

  .footer__deco img {
    display: block;
    width: 100%;
    height: auto;
  }

  .footer__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(12rem, 18.125rem) repeat(3, minmax(7rem, 11.25rem)) minmax(13rem, 1fr);
    gap: 0;
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--footer-padding-top) var(--container-padding-x) var(--footer-padding-bottom);
    align-items: start;
  }

  .footer__brand {
    padding-top: 0;
  }

  .footer__tagline {
    margin-top: 2.5625rem;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    line-height: 1.5;
    color: var(--color-text-muted);
    max-width: var(--footer-tagline-max-width);
    white-space: pre-line;
  }

  .footer__column {
    padding-top: 1.3125rem;
  }

  .footer__column-title {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    line-height: 1.3;
    color: var(--color-text-strong);
    margin-bottom: 3.75rem;
  }

  .footer__column:nth-child(3) .footer__column-title {
    margin-bottom: 3.625rem;
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .footer__links li + li {
    margin-top: 2.125rem;
  }

  .footer__column:nth-child(3) .footer__links li + li {
    margin-top: 2.25rem;
  }

  .footer__column:nth-child(4) .footer__links li + li {
    margin-top: 2.125rem;
  }

  .footer__column:nth-child(4) .footer__links li:nth-child(2) {
    margin-top: 2.25rem;
  }

  /* Figma 95:1445 — Outbound 214×147 */
  .footer__outbound {
    display: flex;
    flex-direction: column;
    gap: 1.625rem;
    width: var(--footer-column-width);
    min-height: 9.1875rem;
    padding-top: 1.3125rem;
  }

  .footer__social {
    display: flex;
    align-items: center;
    gap: 1.5625rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__apps {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer__apps-label {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--font-weight-medium);
    line-height: 1.4;
    letter-spacing: 0.00625rem;
    color: var(--color-text-muted);
    margin: 0;
    padding-left: 0.125rem;
  }

  .footer__store-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4375rem;
    align-items: center;
  }

  .footer__store-badges :global(.store-badge) {
    flex-shrink: 0;
  }

  .footer__copyright {
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    line-height: 1.5;
    color: var(--color-text-muted);
    padding-inline: var(--container-padding-x);
    margin: 0;
  }

  @media (min-width: 1100px) {
    .footer__column-title {
      font-size: var(--text-footer-title);
    }

    .footer__apps-label {
      font-size: var(--text-footer-link);
    }
  }

  .footer__copyright a {
    color: var(--color-brand);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
  }

  .footer__copyright a:hover {
    text-decoration: underline;
  }

  @media (max-width: 1100px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
    }

    .footer__brand,
    .footer__outbound {
      grid-column: 1 / -1;
    }

    .footer__column {
      padding-top: 0;
    }

    .footer__column-title {
      margin-bottom: var(--space-6);
    }

    .footer__links li + li {
      margin-top: var(--space-4);
    }
  }

  @media (max-width: 560px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }

    .footer__deco {
      width: min(18rem, 60vw);
      top: auto;
      bottom: 6rem;
    }
  }
</style>
