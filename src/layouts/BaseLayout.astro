---
import '../styles/global.css';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
import { getLocaleMeta, locales, defaultLocale } from '../config/locales';
import { getLocaleFromPath, getLocalizedPath } from '../lib/i18n';
import type { SiteSettings } from '../types/content';

import type { Locale } from '../config/locales';

interface Props {
  site: SiteSettings;
  title: string;
  description: string;
  ogImage?: string;
  locale?: Locale;
  transparentNav?: boolean;
}

const { site, title, description, ogImage = site.ogImage, locale: localeProp, transparentNav = false } =
  Astro.props;
const locale = localeProp ?? getLocaleFromPath(Astro.url.pathname);
const localeMeta = getLocaleMeta(locale);
const pageDir = localeMeta.dir ?? 'ltr';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
---

<!doctype html>
<html lang={locale} dir={pageDir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? Astro.url).href} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="canonical" href={canonicalUrl.href} />
    {
      locales.map((entry) => (
        <link
          rel="alternate"
          hreflang={entry.code}
          href={new URL(getLocalizedPath(Astro.url.pathname, entry.code), Astro.site ?? Astro.url).href}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(getLocalizedPath(Astro.url.pathname, defaultLocale), Astro.site ?? Astro.url).href}
    />

    <link rel="icon" type="image/png" href="/favicon.png" sizes="50x50" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400&family=Open+Sans:wght@400;600&family=Poppins:wght@400;500;600;700&family=Roboto:wght@400&family=Volkhov:wght@700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class:list={[transparentNav && 'has-transparent-nav']}>
    <Nav site={site} locale={locale} currentPath={Astro.url.pathname} transparent={transparentNav} />
    <main>
      <slot />
    </main>
    <Footer site={site} locale={locale} currentPath={Astro.url.pathname} />
    <script src="/scripts/forms.js" defer></script>
    <script src="/scripts/mock-auth.js" defer></script>
    <script>
      import { initBookTripScroll } from '../lib/book-trip-scroll';
      import { initSmoothScroll } from '../lib/lenis';
      import { destroyLogoTickers, initLogoTickers } from '../lib/logo-ticker';
      import { initScrollReveal } from '../lib/scroll-reveal';

      function initPageMotion() {
        initScrollReveal();
        destroyLogoTickers();
        initLogoTickers();
        initBookTripScroll();
      }

      initSmoothScroll();
      initPageMotion();
      document.addEventListener('astro:page-load', initPageMotion);
    </script>
  </body>
</html>
