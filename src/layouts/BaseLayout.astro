---
import '../styles/global.css';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
import { getLocaleMeta } from '../config/locales';
import { getLocaleFromPath } from '../lib/i18n';
import type { SiteSettings } from '../types/content';

import type { Locale } from '../config/locales';

interface Props {
  site: SiteSettings;
  title: string;
  description: string;
  ogImage?: string;
  locale?: Locale;
}

const { site, title, description, ogImage = site.ogImage, locale: localeProp } = Astro.props;
const locale = localeProp ?? getLocaleFromPath(Astro.url.pathname);
const localeMeta = getLocaleMeta(locale);
const pageDir = localeMeta.dir ?? 'ltr';
---

<!doctype html>
<html lang={locale} dir={pageDir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? Astro.url).href} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/png" href="/favicon.png" sizes="50x50" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400&family=Open+Sans:wght@400;600&family=Poppins:wght@400;500;600;700&family=Roboto:wght@400&family=Volkhov:wght@700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <Nav site={site} locale={locale} currentPath={Astro.url.pathname} />
    <main>
      <slot />
    </main>
    <Footer site={site} />
    <script src="/scripts/forms.js" defer></script>
  </body>
</html>
