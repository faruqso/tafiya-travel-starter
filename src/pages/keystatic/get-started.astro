---
import {
  getTemplateForkUrl,
  getTemplateRepoUrl,
  isKeystaticEditEnabled,
} from '../../lib/keystatic-public';

export const prerender = false;

const reason = Astro.url.searchParams.get('reason');
const editEnabled = isKeystaticEditEnabled();
const githubLoginUrl = '/api/keystatic/github/login';
const hasGithubApp = Boolean(import.meta.env.PUBLIC_KEYSTATIC_GITHUB_APP_SLUG);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Set up Keystatic | tafiya Travel Starter</title>
    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: system-ui, sans-serif;
        background: #f8fafc;
        color: #0f172a;
        line-height: 1.5;
      }

      main {
        max-width: 40rem;
        margin: 0 auto;
        padding: 3rem 1.5rem;
      }

      h1 {
        font-size: 1.75rem;
        margin: 0 0 0.5rem;
      }

      .lead {
        color: #475569;
        margin: 0 0 2rem;
      }

      .notice {
        padding: 1rem 1.25rem;
        margin-bottom: 2rem;
        border-radius: 8px;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1e3a8a;
      }

      ol {
        padding-left: 1.25rem;
        margin: 0 0 2rem;
      }

      li + li {
        margin-top: 0.75rem;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      a.btn {
        display: inline-block;
        padding: 0.65rem 1.1rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9375rem;
      }

      a.btn-primary {
        background: #0f172a;
        color: #fff;
      }

      a.btn-secondary {
        background: #fff;
        color: #0f172a;
        border: 1px solid #cbd5e1;
      }

      a.btn-github {
        background: #24292f;
        color: #fff;
      }

      .back {
        display: inline-block;
        margin-top: 2rem;
        color: #64748b;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Set up your own CMS</h1>
      <p class="lead">
        {
          reason === 'save'
            ? 'Saving changes requires your own copy of this starter and a GitHub App connected to your repo.'
            : reason === 'edit'
              ? 'Editing entries requires your own copy of this starter and a GitHub App connected to your repo.'
              : 'This starter lets anyone browse the CMS demo. To edit and publish content, use your own fork.'
        }
      </p>

      {
        editEnabled ? (
          <div class="notice">
            Editing is enabled on this deployment. If you are the site owner, sign in with GitHub.
          </div>
        ) : (
          <div class="notice">
            This deployment is in <strong>browse-only</strong> mode. Follow the steps below to edit on
            your own site.
          </div>
        )
      }

      <ol>
        <li>
          <a href={getTemplateForkUrl()}>Fork the template</a> to your GitHub account (
          <code>{getTemplateRepoUrl()}</code>)
        </li>
        <li>
          Update <code>KEYSTATIC_REPO</code> in <code>keystatic.config.ts</code> to your{' '}
          <code>username/repo</code>
        </li>
        <li>
          Follow the{' '}
          <a href="https://github.com/faruqso/tafiya-travel-starter/blob/main/docs/keystatic-setup.md">
            Keystatic setup guide
          </a>{' '}
          to create a GitHub App and add the env vars to your host
        </li>
        <li>
          Set <code>PUBLIC_KEYSTATIC_EDIT_ENABLED=true</code> on your deployment when you are ready to
          allow saves
        </li>
      </ol>

      <div class="actions">
        <a class="btn btn-primary" href={getTemplateForkUrl()}>Fork on GitHub</a>
        <a class="btn btn-secondary" href="https://github.com/faruqso/tafiya-travel-starter/blob/main/docs/keystatic-setup.md">
          Read setup guide
        </a>
        {editEnabled && hasGithubApp && (
          <a class="btn btn-github" href={githubLoginUrl}>Sign in with GitHub</a>
        )}
      </div>

      <a class="back" href="/keystatic">← Back to CMS dashboard</a>
    </main>
  </body>
</html>
