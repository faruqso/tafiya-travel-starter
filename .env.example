# Optional: contact form endpoint (Formspree, Netlify Forms, etc.)
# PUBLIC_CONTACT_FORM_URL=https://formspree.io/f/your-form-id

# ── Keystatic GitHub mode (required for editing on Vercel) ──
# 1. Run `npm run dev` and open http://localhost:4321/keystatic
# 2. Click "Login with GitHub" → "Create GitHub App" (one-time setup)
# 3. Copy the generated values below into Vercel → Project → Settings → Environment Variables
# 4. Redeploy
#
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=
# PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
