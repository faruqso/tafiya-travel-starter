{
  "name": "tafiya-travel-starter",
  "type": "module",
  "version": "1.0.0",
  "description": "Open-source Astro + Keystatic travel website starter (tafiya) with a token-driven design system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/faruqso/tafiya-travel-starter.git"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "content:import": "node scripts/import-content.mjs",
    "content:import:dry": "node scripts/import-content.mjs scripts/examples/content-import.sample.csv --dry-run",
    "content:import:json:dry": "node scripts/import-content.mjs scripts/examples/content-import.sample.json --dry-run",
    "content:clone": "node scripts/clone-page-locale.mjs",
    "content:export-catalog": "npx tsx scripts/export-catalog-to-cms.mjs",
    "content:split-catalog": "node scripts/split-catalog-by-locale.mjs",
    "content:seed-page-translations": "node scripts/seed-page-translations.mjs",
    "content:seed-catalog-translations": "node scripts/seed-catalog-translations.mjs",
    "setup:keystatic": "node scripts/setup-keystatic-github.mjs",
    "setup:keystatic:manual": "node scripts/finish-keystatic-github.mjs"
  },
  "dependencies": {
    "@astrojs/markdoc": "^1.0.6",
    "@astrojs/react": "5.0.7",
    "@astrojs/vercel": "^10.0.8",
    "@keystatic/astro": "^5.1.0",
    "@keystatic/core": "^0.5.50",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.8",
    "lenis": "^1.3.25",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-icons": "^16.24.0"
  },
  "keywords": [
    "astro",
    "keystatic",
    "travel",
    "cms",
    "design-system",
    "starter",
    "template"
  ],
  "overrides": {
    "vite": "7.3.5"
  }
}
